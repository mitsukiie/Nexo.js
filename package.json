{
  "name": "nexo.js",
  "version": "1.0.0",
  "type": "module",
  "private": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./types": {
      "types": "./dist/core/types/index.d.ts",
      "import": "./dist/core/types/index.js"
    },
    "./ui": {
      "types": "./dist/core/ui/index.d.ts",
      "import": "./dist/core/ui/index.js"
    },
    "./utils": {
      "types": "./dist/core/utils/index.d.ts",
      "import": "./dist/core/utils/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "bin": {
    "nexo": "./dist/bin/cli.js"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --format esm && bun build src/index.ts --target node --format cjs --outfile dist/index.cjs && bun build src/bin/cli.ts --outdir dist/bin --target node --format esm && bunx tsc --emitDeclarationOnly --outDir dist"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.5.0"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "discord.js": "^14.25.1",
    "glob": "^13.0.6",
    "zod": "^4.3.6"
  }
}
